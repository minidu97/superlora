{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train — LoRTA 3D (paper default)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": ["--preset", "lorta_3d"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train — LoRA Baseline",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": ["--preset", "lora_baseline"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train — SuperLoRA 2D",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": ["--preset", "superlora_2d"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Train — SuperLoRA Projected (rho=0.1)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": ["--preset", "superlora_projected"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Smoke Test (CPU, 10 steps)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train.py",
      "args": [
        "--preset", "lora_baseline",
        "--steps", "10",
        "--batch_size", "8",
        "--device", "cpu"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run Unit Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Pareto Analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/experiments/pareto_analysis.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}